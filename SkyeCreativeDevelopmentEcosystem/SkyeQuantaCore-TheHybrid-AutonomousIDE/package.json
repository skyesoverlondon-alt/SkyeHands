{
  "name": "skyequantacore-thehybrid-autonomouside",
  "private": true,
  "version": "0.1.0",
  "description": "Skyes Over London autonomous IDE platform workspace",
  "scripts": {
    "start": "node apps/skyequanta-shell/bin/launch.mjs",
    "dev": "SKYEQUANTA_DEV=1 node apps/skyequanta-shell/bin/launch.mjs",
    "bootstrap": "node apps/skyequanta-shell/bin/bootstrap.mjs",
    "doctor": "node apps/skyequanta-shell/bin/doctor.mjs && bash scripts/check-self-contained.sh && bash scripts/check-vendor-branding.sh",
    "shell:bootstrap": "node apps/skyequanta-shell/bin/bootstrap.mjs",
    "shell:start": "node apps/skyequanta-shell/bin/launch.mjs",
    "bridge:start": "node apps/skyequanta-shell/bin/bridge.mjs",
    "shell:doctor": "node apps/skyequanta-shell/bin/doctor.mjs",
    "workspace": "node apps/skyequanta-shell/bin/workspace.mjs",
    "workspace:list": "node apps/skyequanta-shell/bin/workspace.mjs list",
    "workspace:current": "node apps/skyequanta-shell/bin/workspace.mjs current",
    "workspace:ensure-default": "node apps/skyequanta-shell/bin/workspace.mjs ensure-default",
    "workspace:start": "node apps/skyequanta-shell/bin/workspace.mjs start local-default",
    "workspace:stop": "node apps/skyequanta-shell/bin/workspace.mjs stop local-default",
    "workspace:runtime": "node apps/skyequanta-shell/bin/workspace.mjs runtime local-default",
    "workspace:ports": "node apps/skyequanta-shell/bin/workspace.mjs ports local-default",
    "workspace:ports:allow": "node apps/skyequanta-shell/bin/workspace.mjs ports:allow local-default --ports 3000",
    "workspace:ports:deny": "node apps/skyequanta-shell/bin/workspace.mjs ports:deny local-default --ports 3000",
    "ide:install": "cd platform/ide-core && npm install",
    "ide:repair": "node apps/skyequanta-shell/bin/ide.mjs repair",
    "ide:prepare": "node apps/skyequanta-shell/bin/ide.mjs prepare",
    "ide:start": "cd platform/ide-core/examples/browser && npm run start",
    "ide:build": "node apps/skyequanta-shell/bin/ide.mjs build",
    "ide:bundle": "node apps/skyequanta-shell/bin/ide.mjs bundle",
    "ide:bundle:frontend": "node apps/skyequanta-shell/bin/ide.mjs bundle --target=frontend",
    "ide:bundle:backend": "node apps/skyequanta-shell/bin/ide.mjs bundle --target=backend",
    "ide:verify": "node apps/skyequanta-shell/bin/ide.mjs verify",
    "agent:backend": "node apps/skyequanta-shell/bin/launch.mjs --agent-only",
    "agent:deps": "cd platform/agent-core && make install-python-dependencies",
    "setup:system": "bash scripts/setup-ubuntu-deps.sh",
    "setup:poetry": "bash scripts/install-poetry.sh",
    "smoke:start": "bash scripts/smoke-startup.sh",
    "doctor:branding": "bash scripts/check-vendor-branding.sh",
    "doctor:self-contained": "bash scripts/check-self-contained.sh",
    "doctor:tree": "find . -maxdepth 2 -mindepth 1 | sort"
  },
  "engines": {
    "node": ">=22"
  }
}